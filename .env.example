# BuchhaltungsButler API Credentials
# Copy this file to .env and fill in your credentials
# Source: Einstellungen → Schnittstellen und API-Zugang
BUCHHALTUNGSBUTLER_CLIENT=your_client_name
BUCHHALTUNGSBUTLER_SECRET=your_api_secret
BUCHHALTUNGSBUTLER_API_KEY=your_api_key
BUCHHALTUNGSBUTLER_BASE_URL=https://webapp.buchhaltungsbutler.de/api/v1
